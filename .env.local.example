# Vercel Postgres (copy from Vercel dashboard → Storage → your DB → .env.local tab)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# NextAuth
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Vercel KV (optional — for session caching)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
